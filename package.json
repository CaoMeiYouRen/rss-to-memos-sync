{
  "name": "rss-to-memos-sync",
  "version": "0.1.0",
  "description": "从 RSS 源同步内容到 Memos",
  "author": "CaoMeiYouRen",
  "private": true,
  "license": "MIT",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "lint": "cross-env NODE_ENV=production eslint . --fix",
    "release": "semantic-release",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production tsup",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:tsup": "cross-env NODE_ENV=development tsup --watch",
    "start": "node ./dist/index.mjs",
    "start:tsx": "cross-env NODE_ENV=production tsx src/index.ts",
    "commit": "cz",
    "prepare": "husky install",
    "dev:vercel": "vercel dev",
    "deploy:vercel": "vercel",
    "dev:wrangler": "wrangler dev --env dev",
    "deploy:wrangler": "wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260421.1",
    "@commitlint/cli": "^20.5.0",
    "@types/debug": "^4.1.12",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.5",
    "@vercel/nft": "^0.27.5",
    "commitizen": "^4.3.1",
    "commitlint-config-cmyr": "^1.0.0",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.3.7",
    "eslint": "^10.2.1",
    "eslint-config-cmyr": "^2.3.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "rimraf": "^6.0.1",
    "semantic-release": "25.0.3",
    "semantic-release-cmyr-config": "^1.0.2",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vercel": "^37.12.1",
    "wrangler": "^3.83.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog-cmyr"
    }
  },
  "changelog": {
    "language": "zh"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  },
  "keywords": [
    "RSS",
    "memos",
    "sync",
    "Docker",
    "Node.js"
  ],
  "homepage": "https://github.com/CaoMeiYouRen/rss-to-memos-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/rss-to-memos-sync.git"
  },
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/rss-to-memos-sync/issues"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.2",
    "@mixmark-io/domino": "^2.2.0",
    "await-to-js": "^3.0.0",
    "better-bytes": "^1.2.4",
    "cheerio": "^1.0.0",
    "cron": "^3.1.7",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "hono": "^4.6.6",
    "isomorphic-unfetch": "^4.0.2",
    "lodash-es": "^4.18.1",
    "p-queue": "^8.0.1",
    "rss-parser": "^3.13.0",
    "tslib": "^2.8.0",
    "turndown": "^7.2.0",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "compare-func": "^2.0.0"
    }
  },
  "type": "module"
}
